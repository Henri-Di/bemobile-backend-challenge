APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:9000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------------------------------------------------------
# Database
# --------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bemobile
DB_USERNAME=laravel
DB_PASSWORD=secret

# --------------------------------------------------------------------
# Cache / Queue / Session
# --------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --------------------------------------------------------------------
# Redis
# --------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------------------------------
# Mail (Mailpit for local development)
# --------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------------------------------
# AWS (optional)
# --------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------------------------------------------------------
# Pusher (optional)
# --------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# --------------------------------------------------------------------
# Payment HTTP configuration
# --------------------------------------------------------------------
PAYMENT_GATEWAY_DEFAULT=gateway_1
PAYMENT_HTTP_TIMEOUT=10
PAYMENT_HTTP_CONNECT_TIMEOUT=5
PAYMENT_HTTP_RETRY_TIMES=2
PAYMENT_HTTP_RETRY_SLEEP=200

# --------------------------------------------------------------------
# Gateway 1 (Mock API)
# --------------------------------------------------------------------
GATEWAY1_BASE_URL=http://gateway_mock:3001
GATEWAY1_LOGIN_EMAIL=dev@betalent.tech
GATEWAY1_LOGIN_TOKEN=your_gateway1_token_here

# --------------------------------------------------------------------
# Gateway 2 (Mock API)
# --------------------------------------------------------------------
GATEWAY2_BASE_URL=http://gateway_mock:3002
GATEWAY2_AUTH_TOKEN=your_gateway2_token_here
GATEWAY2_AUTH_SECRET=your_gateway2_secret_here

# --------------------------------------------------------------------
# Vite
# --------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"